# Copie para `.env` e preencha os valores. Não versione o `.env` (tem segredos).

# ── Banco (Supabase → Settings → Database → Connection string) ──────────────
# Use o driver asyncpg. Prefira a conexão direta (porta 5432).
# Ex.: postgresql+asyncpg://postgres:SENHA@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://usuario:senha@host:5432/postgres

# ── Autenticação (validação do JWT do Supabase) ─────────────────────────────
# Principal: JWKS (chaves assimétricas ES256). Troque o <ref> do projeto.
SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json

# Fallback (legado, opcional): segredo HS256. Só valida sessões antigas que
# ainda não expiraram. Settings → API → JWT Secret. Deixe vazio se não usar.
SUPABASE_JWT_SECRET=

# Audience esperado no token (padrão do Supabase).
JWT_AUDIENCE=authenticated

# ── CORS ────────────────────────────────────────────────────────────────────
# Origens permitidas (front Next.js). Separe múltiplas por vírgula.
CORS_ORIGINS=http://localhost:3000

# ── Desenvolvimento ─────────────────────────────────────────────────────────
# Cria as tabelas no startup (apenas em dev; em produção use migrations).
DEV_CREATE_TABLES=true

# ── Cotações da B3 ──────────────────────────────────────────────────────────
# Token da brapi.dev (https://brapi.dev/dashboard). Opcional — sem ele, as
# cotações ficam indisponíveis, mas a aplicação continua no ar.
BRAPI_TOKEN=
